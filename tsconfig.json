{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "react-router-dom": [
        "./src/router/react-router-dom.tsx"
      ],
      "lucide-react": [
        "./src/components/lucide-react.tsx"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": "."
  }
}